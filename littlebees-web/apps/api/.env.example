# Remote infrastructure - do not point production/staging to localhost
DATABASE_URL="postgresql://USER:PASSWORD@REMOTE_DB_HOST:5432/littlebees?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# API runtime
PORT=3002
NODE_ENV=development
CORS_ORIGINS="https://WEB_HOST,https://ADMIN_HOST"

# Redis
REDIS_URL="redis://REMOTE_REDIS_HOST:6379"

# MinIO / S3-compatible storage
MINIO_ENDPOINT="https://REMOTE_STORAGE_HOST"
MINIO_ACCESS_KEY="CHANGE_ME"
MINIO_SECRET_KEY="CHANGE_ME"
MINIO_BUCKET="littlebees-files"
MINIO_USE_SSL="true"

# Conekta (Payments)
CONEKTA_API_KEY=""
CONEKTA_WEBHOOK_SECRET=""

# Facturapi (CFDI)
FACTURAPI_API_KEY=""

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# Resend (Email)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@kinderspace.mx"

# Twilio (SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SERVICE_SID=""

# Groq AI (Asistente IA)
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
