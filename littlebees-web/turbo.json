{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "generate:openapi": {
      "cache": false,
      "dependsOn": ["@kinderspace/api#build"]
    },
    "generate:ts-client": {
      "dependsOn": ["generate:openapi"],
      "outputs": ["src/generated/**"]
    },
    "generate:dart-client": {
      "dependsOn": ["generate:openapi"],
      "outputs": ["lib/generated/**"]
    }
  }
}
