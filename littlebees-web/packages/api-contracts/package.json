{
  "name": "@kinderspace/api-contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:ts-client": "orval --config orval.config.ts",
    "generate:dart-client": "openapi-generator-cli generate -i ./openapi.yaml -g dart-dio -o ../../apps/mobile/lib/generated --additional-properties=pubName=kinderspace_api",
    "clean": "rm -rf generated"
  },
  "devDependencies": {
    "orval": "^7.3.0",
    "@openapitools/openapi-generator-cli": "^2.15.3",
    "typescript": "^5.7.3"
  }
}
